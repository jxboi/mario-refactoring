# Public client ID used only to show the GitHub sign-in button.
# Create an OAuth App at https://github.com/settings/developers.
VITE_GITHUB_CLIENT_ID=

# Server-only OAuth credentials. Do not use the VITE_ prefix.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:5180/api/auth/callback

# Neon Postgres connection string for the Vercel Function API.
# Vercel's Neon Marketplace integration injects POSTGRES_URL automatically.
POSTGRES_URL=
