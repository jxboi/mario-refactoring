{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "moduleDetection": "force",
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.tmp/tsconfig.node",
    "strict": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "api/**/*.ts", "api/**/*.tsx", "src/types.ts", "src/lib/store.ts", "src/lib/skills.ts", "src/lib/remoteBoard.ts", "src/lib/automations.ts"]
}
